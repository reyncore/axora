# ════════════════════════════════════════════════════
# AXORA — Environment Variables
# Salin file ini ke .env.local dan isi nilainya
# JANGAN commit .env.local ke git!
# ════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────
# Supabase: Settings > Database > Connection string > URI
# Railway:  Dashboard > Variables > DATABASE_URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/axora?schema=public"

# ── Auth.js ──────────────────────────────────────────
# URL deploy kamu (atau http://localhost:3000 untuk dev)
NEXTAUTH_URL="http://localhost:3000"

# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-here"

# ── Cloudflare R2 (File Storage) ──────────────────────
# ── File Storage ───────────────────────────────────────
# Pilih provider: "r2" (default) atau "supabase"
# Tidak perlu isi keduanya — hanya provider yang dipilih yang dipakai.
STORAGE_PROVIDER="r2"

# -- Opsi 1: Cloudflare R2 (S3-compatible) --
# Dashboard R2 > Overview > Account ID
CLOUDFLARE_R2_ACCOUNT_ID=""

# R2 > Manage R2 API tokens > Create API token (Object Read & Write)
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""

# Nama bucket yang sudah dibuat di R2
CLOUDFLARE_R2_BUCKET_NAME="axora-media"

# R2 > Bucket > Settings > Public Access > Enable > Custom Domain atau r2.dev URL
CLOUDFLARE_R2_PUBLIC_URL="https://media.axora.app"

# -- Opsi 2: Supabase Storage --
# Set STORAGE_PROVIDER="supabase" untuk pakai opsi ini.
# Setup: Supabase Dashboard > Storage > New bucket (set sebagai Public)
# URL dan key sama dengan yang dipakai DATABASE_URL/auth Supabase kamu.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="axora-uploads"

# ── Upstash Redis (Rate Limiting — Production) ────────
# https://console.upstash.com > Create Database > REST URL
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Email (Notifikasi) ────────────────────────────────
# Resend: https://resend.com > API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@axora.app"

# ── App Config ────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Axora"

# ── Development only ──────────────────────────────────
# Set ke "true" untuk disable rate limiting di development
DEV_DISABLE_RATE_LIMIT="true"
