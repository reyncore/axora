generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

// USER
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  displayName  String
  bio          String?  @db.Text
  avatarUrl    String?
  bannerUrl    String?
  isVerified        Boolean   @default(false)
  emailVerified     Boolean   @default(false)
  verificationToken String?   @unique
  tokenExpiresAt    DateTime?

  // Password reset — token single-use, expire 1 jam
  resetPasswordToken  String?   @unique
  resetTokenExpiresAt DateTime?

  role       Role      @default(USER)
  isBanned   Boolean   @default(false)
  bannedAt   DateTime?
  banReason  String?

  // Security: digunakan untuk invalidate semua JWT yang diterbitkan sebelum waktu ini
  // Saat password diganti, field ini di-update → semua token lama otomatis invalid
  passwordChangedAt DateTime @default(now())

  // Notification preferences — JSON column, default semua ON
  // Shape: { like: boolean, follow: boolean, comment: boolean, mention: boolean }
  notificationPrefs Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  followers     Follow[]       @relation("Following")
  following     Follow[]       @relation("Follower")
  notifications Notification[] @relation("NotifReceiver")
  triggered     Notification[] @relation("NotifActor")
  sessions      Session[]
  mediaUploads  Media[]

  @@index([username])
  @@index([email])
  // Direct Messages
  sentMessages         Message[]            @relation("MessageSender")
  conversationsAsUser1 Conversation[]       @relation("ConversationUser1")
  conversationsAsUser2 Conversation[]       @relation("ConversationUser2")

  // Bookmarks
  bookmarkCollections  BookmarkCollection[]
  bookmarks            Bookmark[]
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────────────────────────────────────────
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// POST
// ─────────────────────────────────────────────────────────────────────────────
model Post {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String
  parentId  String?  // null = top-level post, ada = reply
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Post?          @relation("PostReplies", fields: [parentId], references: [id])
  replies       Post[]         @relation("PostReplies")
  comments      Comment[]
  likes         Like[]
  media         Media[]
  notifications Notification[]
  bookmarks     Bookmark[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([parentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMENT
// ─────────────────────────────────────────────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String
  postId    String
  createdAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// LIKE
// ─────────────────────────────────────────────────────────────────────────────
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // satu user, satu like per post
  @@index([postId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FOLLOW
// ─────────────────────────────────────────────────────────────────────────────
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────────────────────
model Notification {
  id         String           @id @default(cuid())
  receiverId String
  actorId    String
  type       NotificationType
  postId     String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  receiver User  @relation("NotifReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  actor    User  @relation("NotifActor",    fields: [actorId],    references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([receiverId, isRead])
  @@index([createdAt(sort: Desc)])
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  MENTION
}

// ─────────────────────────────────────────────────────────────────────────────
// MEDIA
// ─────────────────────────────────────────────────────────────────────────────
model Media {
  id         String       @id @default(cuid())
  uploaderId String
  postId     String?
  messageId  String?

  // Storage metadata
  fileUrl    String
  filePath   String       // path di storage bucket — untuk delete
  fileName   String       // nama asli dari user
  mimeType   String
  fileSize   Int          // bytes
  type       MediaType

  // Upload lifecycle
  status     MediaStatus  @default(PENDING)
  purpose    MediaPurpose

  // Dimensions (image + video)
  width      Int?
  height     Int?
  duration   Float?       // detik, untuk video

  // Thumbnail (image + video)
  thumbUrl   String?
  thumbPath  String?

  createdAt  DateTime     @default(now())

  uploader   User         @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  post       Post?        @relation(fields: [postId],     references: [id], onDelete: SetNull)
  message    Message?     @relation(fields: [messageId],  references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([postId])
  @@index([messageId])
  @@index([status, createdAt(sort: Desc)])  // cleanup job: temukan pending lama
}

enum MediaType {
  IMAGE
  VIDEO
  GIF
}

enum MediaStatus {
  PENDING
  READY
  FAILED
}

enum MediaPurpose {
  AVATAR
  COVER
  POST
  MESSAGE
  COMMENT
}


// DIRECT MESSAGES
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Conversation 1-on-1.
 *
 * user1Id selalu < user2Id (string comparison) untuk memastikan
 * unique constraint bekerja tanpa peduli urutan siapa yang memulai chat.
 * Enforced di application layer saat create — lihat lib/conversations.ts
 */
model Conversation {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // di-touch setiap ada message baru, untuk sorting

  user1    User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id, updatedAt(sort: Desc)])
  @@index([user2Id, updatedAt(sort: Desc)])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  media        Media[]

  @@index([conversationId, createdAt(sort: Desc)])
}


// BOOKMARKS
// ─────────────────────────────────────────────────────────────────────────────

/**
 * BookmarkCollection — folder/koleksi yang mengelompokkan bookmark.
 *
 * DESIGN DECISIONS:
 *
 * isDefault: hanya satu koleksi default per user (partial unique index di DB).
 *   Koleksi default di-create lazily saat bookmark pertama kali dibuat.
 *   Koleksi default TIDAK bisa dihapus — enforce di application layer.
 *   Prisma tidak support partial unique index — dibuat manual di migration SQL.
 *
 * isPublic: seluruh koleksi bisa dilihat publik. Individu bookmark di dalam
 *   koleksi publik punya `Bookmark.isVisible` untuk kontrol granular.
 *   `Bookmark.isVisible` HANYA berefek jika `collection.isPublic = true`.
 *
 * slug: URL-friendly identifier, unique per user. Format: kebab-case, a-z0-9-.
 *   Generated dari name di application layer. Race condition di-handle via
 *   retry + DB unique constraint sebagai safety net.
 *   Koleksi default punya slug "semua-bookmark" yang reserved.
 */
model BookmarkCollection {
  id        String   @id @default(cuid())
  userId    String
  name      String   @db.VarChar(50)
  slug      String   @db.VarChar(60)
  isDefault Boolean  @default(false)
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]

  // Slug unique per user — mencegah /putra/collections/foo duplicate
  @@unique([userId, slug])

  // Sorted by activity untuk tampilan list koleksi
  @@index([userId, updatedAt(sort: Desc)])

  // NOTE: partial unique untuk (userId, isDefault=true) TIDAK bisa
  // dideklarasikan di Prisma schema — dibuat manual di migration SQL:
  // CREATE UNIQUE INDEX "one_default_collection_per_user"
  //   ON "BookmarkCollection" ("userId") WHERE "isDefault" = true;
}

/**
 * Bookmark — relasi many-to-many antara User dan Post via Collection.
 *
 * collectionId nullable: null terjadi HANYA sebagai edge case defensive
 *   (misal: race condition saat default collection belum terbentuk).
 *   Normal flow: setiap bookmark selalu punya collectionId.
 *   onDelete: SetNull — kalau koleksi dihapus, application layer sudah
 *   memindahkan bookmark ke default sebelum delete; SetNull sebagai
 *   last-resort safety net bukan primary mechanism.
 *
 * isVisible: kontrol granular per-bookmark dalam koleksi publik.
 *   Diabaikan jika collection.isPublic = false.
 *   Default false: bookmark baru di koleksi publik tidak otomatis publik.
 */
model Bookmark {
  id           String   @id @default(cuid())
  userId       String
  postId       String
  collectionId String?
  isVisible    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  collection BookmarkCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  // Satu user bisa bookmark post yang sama ke banyak koleksi berbeda,
  // tapi tidak duplikat dalam koleksi yang sama
  @@unique([userId, postId, collectionId])

  // Lookup: "apakah user X sudah bookmark post Y?" (untuk PostCard state)
  // Digunakan di setiap feed render — index kritis
  @@index([userId, postId])

  // Pagination dalam koleksi
  @@index([collectionId, createdAt(sort: Desc)])
}
